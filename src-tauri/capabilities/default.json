{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "auth-window",
    "subscription-scraper",
    "scraper-window",
    "post-scraper"
  ],
  "remote": {
    "urls": [
      "https://*.patreon.com",
      "https://patreon.com"
    ]
  },
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "opener:default",
    "dialog:allow-open",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    "sql:default",
    "sql:allow-execute"
  ]
}